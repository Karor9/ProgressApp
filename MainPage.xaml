<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProgressApp.MainPage"
             x:Name="ThisPage"
             xmlns:viewmodel="clr-namespace:ProgressApp.ViewModel"
             xmlns:data="clr-namespace:ProgressApp.Data"
             x:DataType="viewmodel:MainViewModel">

    <Grid RowDefinitions="100, Auto, Auto, *"
          ColumnDefinitions=".50*, .25*, .25*"
          Padding="10"
          RowSpacing="10"
          ColumnSpacing="10">

        <Image Grid.ColumnSpan="2"
               Source="dotnet_bot.png"
               BackgroundColor="Transparent"/>

        <Entry Placeholder="Enter name"
               Grid.Row="1"
               Grid.ColumnSpan="2"
               Grid.Column="0"
               Text="{Binding Text}"/>
        <Button Text="Add"
                Command="{Binding AddCommand}"
                Grid.Row="1"
                Grid.Column="2"/>
        <Entry Placeholder="Current Chapter"
               Grid.Row="2"
               Grid.Column="0"
               Text="{Binding CurrentChapter}"/>
        <Entry Placeholder="Max Chapters"
               Grid.Row="2"
               Grid.ColumnSpan="2"
               Grid.Column="1"
               Text="{Binding TotalChapter}"/>
        <CollectionView Grid.Row="3" Grid.ColumnSpan="4"
                        ItemsSource="{Binding Items}">
            
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="data:DataClass">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           Command="{Binding BindingContext.DeleteCommand, Source={x:Reference ThisPage}}"
                                           CommandParameter="{Binding .}"
                                           />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border>
                            <Grid Padding="0,2"
                                  ColumnDefinitions=".8*, .085*, .03*, .085*"
                                  RowSpacing="10"
                                  ColumnSpacing="10"
                                  >
                                <Label Text="{Binding FieldName}"
                                       FontSize="24"
                                       Grid.Column="0"
                                       VerticalTextAlignment="Center"
                                        />
                                <Label Text="{Binding CurrentChapter}"
                                        FontSize="24"
                                       Grid.Column="1"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center"
                                        />
                                <Label Text="/"
                                        FontSize="24"
                                       Grid.Column="2"
                                       VerticalTextAlignment="Center"
                                        />
                                <Label Text="{Binding MaxChapter}"
                                        FontSize="24"
                                       Grid.Column="3"
                                       VerticalTextAlignment="Center"
                                       />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
